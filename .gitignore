# DJ Management System – .gitignore

# Environment variables
.env

# Dependencies
node_modules/
*/node_modules/

# Build output
frontend/dist/

# Uploaded media (user data – don't commit)
uploads/*
!uploads/.gitkeep

# Database (user data – don't commit)
backend/db.json

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
